@startuml Communication Diagram
title Diagrama de Comunicación - Buscador y Notificador de Empleos (scripts-backend)

skinparam responseMessageAlign center

actor "Cloud Scheduler" as scheduler
boundary "scripts_route" as router
control "security" as sec
control "job_controller" as jobCtrl
control "db_controller" as dbCtrl
control "email_controller" as emailCtrl
database "Firestore DB" as db
entity "Gmail SMTP" as smtp

scheduler -> router : 1: GET /scripts/run-job-finder
router -> sec : 2: verify_security_from_google_cloud_scheduler_task(request)
sec --> router : 3: Verification success

router -> jobCtrl : 4: run_job_finder_workflow(db, user, pass)

jobCtrl -> jobCtrl : 5: fetch_all_active_jobs()
jobCtrl -> jobCtrl : 6: filter_jobs(items, pattern)

jobCtrl -> dbCtrl : 7: check_and_filter_already_sent(db, filtered_jobs)
dbCtrl -> db : 8: Consultar por URL
db --> dbCtrl : 9: return times_sent
dbCtrl --> jobCtrl : 10: return new_jobs_to_send

jobCtrl -> emailCtrl : 11: send_email(server, sender, recipients, subject, body)
emailCtrl -> smtp : 12: Dispatch emails via TLS
smtp --> emailCtrl : 13: Success confirmation
emailCtrl --> jobCtrl : 14: return is_sent_ok

jobCtrl -> dbCtrl : 15: increment_sent_count(db, sent_jobs)
dbCtrl -> db : 16: update/increment doc (times_sent)

jobCtrl -> dbCtrl : 17: cleanup_inactive_jobs(db, raw_jobs)
dbCtrl -> db : 18: Delete documents of closed jobs

@enduml
