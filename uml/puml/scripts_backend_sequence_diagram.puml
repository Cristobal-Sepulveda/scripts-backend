@startuml Sequence Diagram
title Diagrama de Secuencia - Buscador y Notificador de Empleos (scripts-backend)

actor "Cloud Scheduler" as scheduler
participant "scripts_controller\n(FastAPI)" as router
participant "middleware\n(verify_security)" as mid
participant "RunKineJobFinderUseCase\n(Domain UseCase)" as kineUc
participant "RunMatronJobFinderUseCase\n(Domain UseCase)" as matronUc
participant "CleanupInactiveJobsUseCase\n(Domain UseCase)" as cleanupUc
participant "FirestoreJobRepository\n(Data DB)" as repo
database "Firestore DB" as db
participant "GmailEmailService\n(Data Service)" as mail
entity "Gmail SMTP Server" as smtp

== Flujo 1: Kinesiología (GET /scripts/run-job-finder/kinesiologia) ==
scheduler -> router: HTTP GET /scripts/run-job-finder/kinesiologia
activate router

router -> mid: verify_security_from_google_cloud_scheduler_task(request)
activate mid
mid --> router: Verification success
deactivate mid

router -> repo: instantiate FirestoreJobRepository(db)
router -> mail: instantiate GmailEmailService(user, pass)
router -> kineUc: instantiate RunKineJobFinderUseCase(repo, mail)

router -> kineUc: execute()
activate kineUc

kineUc -> repo: fetch_all_active_jobs()
activate repo
repo --> kineUc: list[dict] (all_items)
deactivate repo

kineUc -> kineUc: _filter_jobs(all_items, KINE_PATTERN)
loop Para cada oferta
    kineUc -> repo: get_sent_job_by_url(job.url)
    activate repo
    repo -> db: Consultar doc por filtro URL
    activate db
    db --> repo: Retorna doc (o None)
    deactivate db
    repo --> kineUc: bool (True/False)
    deactivate repo
    alt Si no fue enviado (False)
        kineUc -> repo: save_job(job)
        activate repo
        repo -> db: Guardar documento en Firestore
        deactivate repo
    end
end

kineUc -> mail: Context Manager: __enter__()
activate mail
mail -> smtp: Conectar smtp.gmail.com:587, starttls(), login()
activate smtp
smtp --> mail: Conectado y autenticado
deactivate smtp
mail --> kineUc: active session
deactivate mail

alt Hay ofertas de Kinesiólogo a enviar
    kineUc -> mail: send_email(kine_recipients, subject, kine_body)
    activate mail
    mail -> smtp: Dispatch email
    smtp --> mail: OK
    mail --> kineUc: true
    deactivate mail
    
end

kineUc -> mail: Context Manager: __exit__()
activate mail
mail -> smtp: quit()
deactivate mail

kineUc --> router: Executed successfully
deactivate kineUc
router --> scheduler: HTTP 200 OK (Status success)
deactivate router


== Flujo 2: Matronería (GET /scripts/run-job-finder/matroneria) ==
scheduler -> router: HTTP GET /scripts/run-job-finder/matroneria
activate router

router -> mid: verify_security_from_google_cloud_scheduler_task(request)
activate mid
mid --> router: Verification success
deactivate mid

router -> repo: instantiate FirestoreJobRepository(db)
router -> mail: instantiate GmailEmailService(user, pass)
router -> matronUc: instantiate RunMatronJobFinderUseCase(repo, mail)

router -> matronUc: execute()
activate matronUc

matronUc -> repo: fetch_all_active_jobs()
activate repo
repo --> matronUc: list[dict] (all_items)
deactivate repo

matronUc -> matronUc: _filter_jobs(all_items, MATRON_PATTERN)
loop Para cada oferta
    matronUc -> repo: get_sent_job_by_url(job.url)
    activate repo
    repo -> db: Consultar doc por filtro URL
    activate db
    db --> repo: Retorna doc (o None)
    deactivate db
    repo --> matronUc: bool (True/False)
    deactivate repo
    alt Si no fue enviado (False)
        matronUc -> repo: save_job(job)
        activate repo
        repo -> db: Guardar documento en Firestore
        deactivate repo
    end
end

matronUc -> mail: Context Manager: __enter__()
activate mail
mail -> smtp: Conectar
activate smtp
smtp --> mail: Conectado
deactivate smtp
mail --> matronUc: active session
deactivate mail

alt Hay ofertas de Matrón(a) a enviar
    matronUc -> mail: send_email(matron_recipients, subject, matron_body)
    activate mail
    mail -> smtp: Dispatch email
    smtp --> mail: OK
    mail --> matronUc: true
    deactivate mail
    
end

matronUc -> mail: Context Manager: __exit__()
activate mail
mail -> smtp: quit()
deactivate mail

matronUc --> router: Executed successfully
deactivate matronUc
router --> scheduler: HTTP 200 OK (Status success)
deactivate router


== Flujo 3: Mantenimiento (GET /scripts/run-job-finder/cleanup) ==
scheduler -> router: HTTP GET /scripts/run-job-finder/cleanup
activate router

router -> mid: verify_security_from_google_cloud_scheduler_task(request)
activate mid
mid --> router: Verification success
deactivate mid

router -> repo: instantiate FirestoreJobRepository(db)
router -> cleanupUc: instantiate CleanupInactiveJobsUseCase(repo)

router -> cleanupUc: execute()
activate cleanupUc

cleanupUc -> repo: fetch_all_active_jobs()
activate repo
repo --> cleanupUc: list[dict] (all_items)
deactivate repo

cleanupUc -> repo: cleanup_inactive_jobs(active_urls)
activate repo
repo -> db: Eliminar ofertas inactivas de Firestore
deactivate repo

cleanupUc --> router: Executed successfully
deactivate cleanupUc
router --> scheduler: HTTP 200 OK (Status success)
deactivate router

@enduml
