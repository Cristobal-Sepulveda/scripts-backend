@startuml C4 System Context Diagram
title Diagrama C4 - Buscador y Notificador de Empleos (scripts-backend)

actor "Destinatarios (Familia/Amigos)" as user

rectangle "Cloud Scheduler" as scheduler

rectangle "GCP - Cloud Run & Firestore" {
    rectangle "FastAPI Backend Application\n(Python / FastAPI)\n--\nOrquesta la consulta del portal, filtros y envíos." as api
    database "Cloud Firestore Database\n(NoSQL Firestore)\n--\nAlmacena logs de ofertas ya enviadas y su estado." as db
}

rectangle "Portal Empleos Públicos API" as portal
rectangle "Gmail SMTP Server" as smtp

scheduler --> api : "1. Dispara cron (HTTP GET)"
api --> portal : "2. Obtiene ofertas (HTTP GET)"
api --> db : "3. Lee/escribe historial (gcloud SDK)"
api --> smtp : "4. Envía correos (SMTP TLS)"
smtp --> user : "5. Notifica ofertas de interés (Email)"

@enduml
